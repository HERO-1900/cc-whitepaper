---
// [...]slug.astro — 章节动态路由
// 每个章节 Markdown 文件生成一个独立页面
// URL 格式：/chapters/part0/00-序章

import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ChartEmbed from '../../components/ChartEmbed.astro';
import { BOOK_STRUCTURE, ALL_CHAPTERS } from '../../data/book-structure';

// 告诉 Astro 需要生成哪些静态页面
export async function getStaticPaths() {
  const bookEntries = await getCollection('book');

  const validEntries = bookEntries.filter((entry) => {
    // 过滤掉：
    // 1. 根目录文件（如 references.md）—— 只有一段路径
    // 2. _shared/ 下的文件（辅助数据，不是章节）
    const parts = entry.id.split('/');
    if (parts.length < 2) return false;
    if (parts[0] === '_shared') return false;
    return true;
  });

  return validEntries.map((entry) => {
    // entry.id 形如 "part0_序章/00_序章.md"
    // 转换成 URL slug
    const idNoExt = entry.id.replace(/\.md$/, '');
    const parts = idNoExt.split('/');
    const partSeg = parts[0].replace(/_[^_]+$/, ''); // part0_序章 → part0
    const chapterSeg = parts[1].replace(/_/g, '-').toLowerCase();
    const slug = `${partSeg}/${chapterSeg}`;

    return {
      params: { slug },
      props: { entry, slug },
    };
  });
}

// 接收动态路由参数
const { entry, slug } = Astro.props;

// 渲染 Markdown 内容
const { Content } = await render(entry);

// 找到当前章节在全局列表中的位置，用于上一章/下一章导航
const currentIndex = ALL_CHAPTERS.findIndex((c) => c.slug === slug);
const prevChapter = currentIndex > 0 ? ALL_CHAPTERS[currentIndex - 1] : null;
const nextChapter = currentIndex < ALL_CHAPTERS.length - 1 ? ALL_CHAPTERS[currentIndex + 1] : null;

// 找到当前章节标题（优先用 front-matter，否则用 BOOK_STRUCTURE 里的 title）
const chapterMeta = ALL_CHAPTERS.find((c) => c.slug === slug);
const pageTitle = entry.data.title || chapterMeta?.title || '章节';

// 判断是否是序章（序章含有图表嵌入的 PoC 演示）
const isProlog = slug === 'part0/00-序章';
---

<Layout title={pageTitle} currentSlug={slug}>
  <article class="prose">
    <!-- 章节 Markdown 内容渲染 -->
    <Content />

    <!--
      图表嵌入 PoC（仅在序章页面展示）
      验证：iframe 在 Astro MPA 路由下能否正常加载
    -->
    {isProlog && (
      <section>
        <h2>附：英雄架构图（图表嵌入 PoC）</h2>
        <p>
          以下图表通过 <code>&lt;iframe&gt;</code> 嵌入，文件来自
          <code>public/charts/VIS-0-001_英雄架构图.html</code>，
          验证 Astro 静态路由 + 图表 iframe 的兼容性。
        </p>
        <ChartEmbed
          src="VIS-0-001_英雄架构图.html"
          title="CC 系统架构全景图（VIS-0-001）"
          height={560}
          id="chart-vis-0-001"
        />
      </section>
    )}
  </article>

  <!-- 章节翻页导航 -->
  <nav class="chapter-nav" aria-label="章节翻页">
    {prevChapter ? (
      <a href={`/chapters/${prevChapter.slug}`} class="chapter-nav__btn">
        <span class="chapter-nav__label">← 上一章</span>
        <span class="chapter-nav__title">{prevChapter.title}</span>
      </a>
    ) : (
      <span></span>
    )}

    {nextChapter ? (
      <a href={`/chapters/${nextChapter.slug}`} class="chapter-nav__btn" style="text-align: right; margin-left: auto;">
        <span class="chapter-nav__label">下一章 →</span>
        <span class="chapter-nav__title">{nextChapter.title}</span>
      </a>
    ) : null}
  </nav>
</Layout>
