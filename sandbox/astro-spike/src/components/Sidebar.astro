---
// Sidebar.astro — 章节导航侧边栏
import { BOOK_STRUCTURE } from '../data/book-structure';

interface Props {
  currentSlug?: string;
}

const { currentSlug } = Astro.props;
---

<nav class="sidebar" aria-label="章节导航">
  <p class="sidebar__title">CC 白皮书</p>

  {BOOK_STRUCTURE.map((part) => (
    <div class="sidebar__part">
      <p class="sidebar__part-title">{part.title}</p>
      <ul class="sidebar__nav-list">
        {part.chapters.map((chapter) => (
          <li class="sidebar__nav-item">
            <a
              href={`/chapters/${chapter.slug}`}
              class={currentSlug === chapter.slug ? 'active' : ''}
            >
              {chapter.title}
            </a>
          </li>
        ))}
      </ul>
    </div>
  ))}
</nav>
