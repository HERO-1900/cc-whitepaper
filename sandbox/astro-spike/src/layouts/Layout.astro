---
// Layout.astro — 主布局
// 包含：顶部导航（含主题切换）+ 侧边栏 + 正文区

import Sidebar from '../components/Sidebar.astro';
import '../styles/tokens.css';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  currentSlug?: string;
}

const {
  title = 'Claude Code 白皮书',
  description = 'Claude Code 2.1.88 源码完全解构，87 章中文深度解析。',
  currentSlug,
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} — CC 白皮书</title>
    <link rel="icon" href="/favicon.ico" />

    <!--
      主题初始化脚本：必须是 inline script，在 CSS 解析前运行，
      防止"亮色闪烁"（FOUC），与 sandbox/theme-tokens.css 的
      [data-theme="dark/light"] 约定对齐。
      --cc-* token 命名约定遵循前端阶段 1 子 Agent 的规范。
    -->
    <script is:inline>
      (function() {
        try {
          var saved = localStorage.getItem('cc-theme');
          var preferred = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
          var theme = saved || preferred;
          document.documentElement.setAttribute('data-theme', theme);
        } catch(e) {}
      })();
    </script>
  </head>

  <body>
    <!-- 顶部导航栏 -->
    <header class="topnav">
      <a href="/" class="topnav__logo">CC 白皮书 · PoC</a>

      <button
        class="theme-toggle"
        id="themeToggleBtn"
        aria-label="切换明暗主题"
        title="切换明暗主题"
      >
        <span id="themeIcon">🌙</span>
        <span id="themeLabel">暗色</span>
      </button>
    </header>

    <!-- 主体布局 -->
    <div class="layout-body">
      <Sidebar currentSlug={currentSlug} />

      <main class="content-area">
        <slot />
      </main>
    </div>

    <!-- 主题切换逻辑 -->
    <script>
      function initThemeToggle() {
        const btn = document.getElementById('themeToggleBtn');
        const icon = document.getElementById('themeIcon');
        const label = document.getElementById('themeLabel');
        if (!btn || !icon || !label) return;

        function updateUI(theme: string) {
          if (theme === 'dark') {
            icon.textContent = '🌙';
            label.textContent = '暗色';
          } else {
            icon.textContent = '☀️';
            label.textContent = '亮色';
          }
        }

        // 初始化 UI
        const current = document.documentElement.getAttribute('data-theme') || 'dark';
        updateUI(current);

        btn.addEventListener('click', () => {
          const curr = document.documentElement.getAttribute('data-theme') || 'dark';
          const next = curr === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', next);
          try { localStorage.setItem('cc-theme', next); } catch(e) {}
          updateUI(next);
        });
      }

      // Astro 的 ViewTransitions 下需要在每次导航后重新绑定
      document.addEventListener('DOMContentLoaded', initThemeToggle);
    </script>
  </body>
</html>
