# ============================================================
# 环境变量样板 — 复制为 .env 后填入真实 key
# .env 已被 .gitignore，永不入库
# ============================================================

# Kimi Coding Plan 网关 (https://api.kimi.com/coding/)
# 用于 scripts/chart-pipeline*.sh / chart-revision*.sh
KIMI_API_KEY=sk-kimi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# MiniMax / ChatPlus 网关 (https://api.minimaxi.com/anthropic)
# 用于 scripts/chart-pipeline*.sh / chart-revision*.sh 的评审环节
MINIMAX_API_KEY=sk-cp-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
